# OpenAI API Configuration (for local development only)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# AI Assessment Configuration (for local development only)
VITE_AI_MODEL=gpt-3.5-turbo
VITE_AI_MAX_TOKENS=1000
VITE_AI_TEMPERATURE=0.7

# SEO and Analytics Configuration
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_GADS_TRACKING_ID=AW-XXXXXXXXXX
VITE_GOOGLE_SITE_VERIFICATION=your_google_search_console_verification_code
VITE_BING_VERIFICATION=your_bing_verification_code

# Netlify CMS
VITE_NETLIFY_SITE_ID=your_netlify_site_id

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id


# Note: In production, these variables should be set in Netlify without VITE_ prefix:
# OPENAI_API_KEY=your_actual_api_key
# AI_MODEL=gpt-3.5-turbo  
# AI_MAX_TOKENS=1000
# AI_TEMPERATURE=0.7
