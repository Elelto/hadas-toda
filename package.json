{
  "name": "hadas-toda-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-content.js && vite",
    "update-blog": "node scripts/update-blog-data.js",
    "optimize-rec": "node scripts/optimize-recommendations.js",
    "prebuild": "npm run update-blog && node scripts/generate-sitemap.js && npm run optimize-rec",
    "build": "node scripts/sync-content.js && vite build",
    "postbuild": "node scripts/inject-seo-meta.js",
    "preview": "vite preview",
    "cms": "npx netlify-cms-proxy-server",
    "sync-content": "node scripts/sync-content.js",
    "watch-content": "node scripts/sync-content.js --watch",
    "start-cms": "node start-cms.js",
    "dev-cms": "concurrently \"npm run dev\" \"npm run cms\""
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "aos": "^2.3.4",
    "buffer": "^6.0.3",
    "firebase": "^12.15.0",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^5.0.0",
    "markdown-it": "^14.2.0",
    "netlify-identity-widget": "^2.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.1",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^10.0.3",
    "netlify-cms-proxy-server": "^1.3.24",
    "openai": "^6.16.0",
    "sharp": "^0.35.2",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.31.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-prerender": "^1.0.8"
  }
}
